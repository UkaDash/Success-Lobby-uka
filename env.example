# ============================================================
#  CPCC Student Portal — Environment Variables
#  File: .env  (never commit this to Git!)
# ============================================================

# ── Server ──────────────────────────────
PORT=5000
CLIENT_URL=http://localhost:3000

# ── MySQL Database ───────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=cpcc_portal

# ── JWT ──────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES=7d
